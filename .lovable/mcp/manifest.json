{
  "version": 1,
  "sdk_version": "0.22.2",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://myjynbqzlovanoarppyt.supabase.co/auth/v1",
    "accepted_audiences": ["authenticated"]
  },
  "mcp": {
    "server": {
      "name": "jarvis-mcp",
      "version": "0.1.0",
      "title": "JARVIS"
    },
    "tools": [
      {
        "name": "list_tasks",
        "title": "List tasks",
        "description": "List the signed-in user's JARVIS tasks, optionally filtered by status.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "status": {
              "description": "Optional status filter.",
              "type": "string",
              "enum": ["todo", "in_progress", "done", "cancelled"]
            },
            "limit": {
              "description": "Max rows (default 25).",
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "create_task",
        "title": "Create task",
        "description": "Create a new task for the signed-in user.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200,
              "description": "Short task title."
            },
            "details": {
              "description": "Optional longer description.",
              "type": "string",
              "maxLength": 4000
            },
            "priority": {
              "description": "Priority 0-5 (default 2).",
              "type": "integer",
              "minimum": 0,
              "maximum": 5
            },
            "tags": {
              "maxItems": 20,
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 40
              }
            }
          },
          "required": ["title"]
        },
        "outputSchema": null
      },
      {
        "name": "list_notes",
        "title": "List notes",
        "description": "List the signed-in user's saved JARVIS notes.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "description": "Max rows (default 25).",
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "create_note",
        "title": "Create note",
        "description": "Save a new note to the signed-in user's JARVIS notes.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200,
              "description": "Short note title."
            },
            "body": {
              "description": "Note body / content.",
              "type": "string",
              "maxLength": 20000
            },
            "tags": {
              "maxItems": 20,
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 40
              }
            }
          },
          "required": ["title"]
        },
        "outputSchema": null
      },
      {
        "name": "list_agents",
        "title": "List agents",
        "description": "List JARVIS sub-agents registered for the signed-in user.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      }
    ]
  }
}
